# ==========================================
# FlowCheck Root GitIgnore Consolidation
# ==========================================

# Gradle / Java Build Outputs
.gradle/
**/build/
**/out/
**/bin/
*.class

# Node.js / Frontend Outputs
node_modules/
**/node_modules/
dist/
dist-ssr/
.next/
out/
.nuxt/
.cache/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Python Cache (Legacy & Helpers)
__pycache__/
*.py[cod]
*$py.class
venv/
.venv/
.pytest_cache/
.coverage
htmlcov/

# IDEs & Editors
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS Files
.DS_Store
Thumbs.db
desktop.ini

# Environment Variables & Secrets
.env
.env.*
!.env.example
*.pem
*.key
*.cert

# Databases
*.db
*.sqlite3
*.log

# Locust / Load Test Outputs
*stats.csv
*stats_history.csv
*failures.csv
*exceptions.csv
locust.log
temp_locust*.py
report.html
