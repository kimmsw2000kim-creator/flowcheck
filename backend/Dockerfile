# backend/Dockerfile

# ======================================================================
#  1. Build Stage: 소스코드를 컴파일하여 .jar 파일을 만드는 단계
# ======================================================================

# Gradle과 JDK 17이 모두 포함된 이미지를 'builder'라는 별명의 빌드 환경으로 사용
FROM gradle:jdk17-focal AS builder
